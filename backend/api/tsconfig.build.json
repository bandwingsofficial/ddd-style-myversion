{
  "extends": "./tsconfig.json",

  "compilerOptions": {
    /* 🔥 FORCE LEGACY NESTJS COMPILATION 🔥 */
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,

    /* Build output */
    "outDir": "./dist",

    /* Types */
    "types": ["node", "express", "jest"],
    "typeRoots": [
      "./src/types",
      "./node_modules/@types"
    ]
  },

  "exclude": [
    "node_modules",
    "test",
    "dist",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
