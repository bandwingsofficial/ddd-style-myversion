//////////////////////////////////////////////////////
// GENERATOR & DATASOURCE
//////////////////////////////////////////////////////

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS (DOMAIN-ALIGNED)
//////////////////////////////////////////////////////

enum ActorType {
  CUSTOMER
  DELIVERY
  OUTLET_USER
  SUPER_ADMIN
}
enum OutletUserRole {
  ADMIN
  MANAGER
  STAFF
}

enum OtpPurpose {
  LOGIN
  VERIFY_PHONE
  SENSITIVE_ACTION
}

enum DeliveryStatus {
  CREATED
  KYC_SUBMITTED
  APPROVED
  REJECTED
  SUSPENDED
  BLOCKED
}

enum AuditAction {

  OTP_REQUESTED
  OTP_VERIFICATION_FAILED
  OTP_VERIFIED

  LOGIN_SUCCESS
  LOGIN_FAILED
  MFA_FAILED

  TOKEN_ISSUED
  TOKEN_REFRESHED
  TOKEN_REUSE_DETECTED


  LOGOUT
  LOGOUT_ALL
  SESSION_REVOKED


  DELIVERY_APPROVED
  DELIVERY_REJECTED
  DELIVERY_SUSPENDED
  DELIVERY_BLOCKED


  OUTLET_USER_CREATED
  OUTLET_USER_DISABLED
  OUTLET_USER_DELETED
  OUTLET_USER_ENABLED
  OUTLET_USER_PASSWORD_RESET


  OUTLET_CREATED
  OUTLET_UPDATED
  OUTLET_ENABLED
  OUTLET_DISABLED

  OUTLET_OPENED
  OUTLET_CLOSED
  OUTLET_TEMPORARILY_CLOSED

  OUTLET_CAMERA_ON
  OUTLET_CAMERA_OFF
  OUTLET_CAMERA_MAINTENANCE


  SUPER_ADMIN_LOGIN
  SUPER_ADMIN_ACTION
}

enum OutletStatus {
  ACTIVE
  INACTIVE
}

enum OutletWorkingStatus {
  OPEN
  CLOSED
  TEMPORARILY_CLOSED
}

enum CameraStatus {
  OFF
  ON
  MAINTENANCE
}


//////////////////////////////////////////////////////
// CORE AUTH (SESSION = SOURCE OF TRUTH)
//////////////////////////////////////////////////////

model AuthSession {
  id         String    @id @default(cuid())
  actorType ActorType
  actorId   String
  deviceId  String?
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())
  lastUsedAt DateTime
  revokedAt  DateTime?

  refreshTokens RefreshToken[]
  audits        AuditLog[]

  @@index([actorType, actorId])
  @@index([revokedAt])
}

model RefreshToken {
  id            String   @id @default(cuid())
  sessionId     String
  tokenHash     String   @unique
  createdAt     DateTime @default(now())
  expiresAt     DateTime
  rotatedAt     DateTime?
  replacedById  String?

  session AuthSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([tokenHash])
  @@index([expiresAt])
}

//////////////////////////////////////////////////////
// OTP TRACKING
//////////////////////////////////////////////////////

model OtpRequest {
  id         String @id @default(cuid())
  actorType ActorType
  actorId   String?
  phone     String
  purpose   OtpPurpose
  otpHash   String
  attempts  Int    @default(0)
  expiresAt DateTime
  verifiedAt DateTime?
  createdAt DateTime @default(now())

  @@index([phone, purpose])
  @@index([expiresAt])
}

//////////////////////////////////////////////////////
// MFA
//////////////////////////////////////////////////////

model MfaChallenge {
  id         String @id @default(cuid())
  actorType ActorType
  actorId   String
  expiresAt DateTime
  verifiedAt DateTime?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([actorType, actorId])
  @@index([expiresAt])
}

//////////////////////////////////////////////////////
// AUDIT LOG
//////////////////////////////////////////////////////

model AuditLog {
  id         String @id @default(cuid())
  actorType ActorType
  actorId   String?
  sessionId String?
  action    AuditAction
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  session AuthSession? @relation(fields: [sessionId], references: [id])

  @@index([actorType, actorId])
  @@index([action])
  @@index([createdAt])
}

//////////////////////////////////////////////////////
// IDENTITY TABLES (NO AUTH LOGIC)
//////////////////////////////////////////////////////

model Customer {
  id           String @id @default(cuid())
  phone        String @unique
  isBlocked    Boolean @default(false)
  blockedAt    DateTime?
  tokenVersion Int @default(0)
  createdAt    DateTime @default(now())

  orders Order[]
  carts Cart[]
  profile CustomerProfile?
  
  savedAddresses CustomerSavedAddress[]
}

model CustomerProfile {
  id String @id @default(cuid())

  customerId String @unique
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  fullName   String?
  email      String?  @unique
  avatarUrl  String?

  gender     String?
  dob        DateTime?

  referralCode String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
}

model DeliveryPartner {
  id           String @id @default(cuid())
  phone        String @unique
  status       DeliveryStatus @default(CREATED)
  kycRefId     String?
  approvedAt   DateTime?
  approvedBy   String?
  tokenVersion Int @default(0)
  createdAt    DateTime @default(now())

  deliveries Delivery[]
}

//////////////////////////////////////////////////////
// OUTLET DOMAIN
//////////////////////////////////////////////////////

model Outlet {
  id        String @id @default(cuid())

  // Identity
  name      String
  branch    String?
  address   String?
  location  String?
  pincode   String?

  // Geo
  latitude  Float?
  longitude Float?

  // Admin control
  status OutletStatus @default(ACTIVE)
  isActive     Boolean @default(true)

  // Customer-facing availability
  workingStatus OutletWorkingStatus @default(CLOSED)

  // Camera
  isCameraEnabled Boolean @default(false)
  cameraStatus    CameraStatus @default(OFF)
  cameraStreamUrl String?

  // Config
  deliveryRadiusKm Float?
  isCentral         Boolean @default(false)

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  profile   OutletProfile?

  users  OutletUser[]
  outletStocks OutletStock[]
  orders Order[]
  carts Cart[]
  products OutletProduct[]
}

model OutletUser {
  id       String @id @default(cuid())
  outletId String

  // Auth
  email        String @unique
  passwordHash String
  isActive     Boolean @default(true)

  // Security
  failedAttempts Int @default(0)
  lockedUntil    DateTime?
  tokenVersion   Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outlet Outlet @relation(fields: [outletId], references: [id])

  @@index([outletId])
}

model OutletProfile {
  id String @id @default(cuid())

  outletId String @unique
  outlet   Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  logoUrl   String?
  bannerUrl String?

  contactPhone String?
  contactEmail String?

  ownerName String?
  description String?

  gstNumber    String?
  fssaiNumber  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([outletId])
}

model OutletProduct {
  id String @id @default(uuid())

  outletId  String
  productId String

  outlet  Outlet  @relation(fields: [outletId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // outlet-specific controls
  isAvailable Boolean @default(true)

  priceOverride     Decimal? @db.Decimal(12,2)
  discountOverride  Decimal? @db.Decimal(12,2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([outletId, productId])
  @@index([outletId])
  @@index([productId])
}

//////////////////////////////////////////////////////
// SUPER ADMIN
//////////////////////////////////////////////////////

model SuperAdmin {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String
  totpSecret   String?
  mfaEnabled   Boolean @default(true)
  isActive     Boolean @default(true)
  tokenVersion Int @default(0)
  createdAt    DateTime @default(now())

  profile SuperAdminProfile?
}

model SuperAdminProfile {
  id String @id @default(cuid())

  superAdminId String @unique
  superAdmin   SuperAdmin @relation(fields: [superAdminId], references: [id], onDelete: Cascade)

  fullName  String
  avatarUrl String?
  title     String? // e.g. Ops Head, Tech Lead

  phone     String?
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([superAdminId])
}

//////////////////////////////////////////////////////
// Product /catagory
//////////////////////////////////////////////////////

enum CategoryStatus {
  ACTIVE
  INACTIVE
}

model Category {
  id        String         @id @default(uuid())
  name      String
  subtitle  String?        // optional subtitle
  imagePath String?        // local stored image path: images/categories/*
  status    CategoryStatus
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  products Product[]
}


//////////////////////////////////////////////////////
// Product /stockitems
//////////////////////////////////////////////////////

enum StockItemStatus {
  ACTIVE
  INACTIVE
}

enum Unit {
  KG
  GRAM
  LITER
  ML
  PIECE
  PACKET
}

model StockItem {
  id        String           @id @default(cuid())
  name      String           @unique @db.VarChar(100)
  unit      Unit
  status    StockItemStatus  @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  // 🔁 RELATIONS (REQUIRED)
  centralInventory CentralInventory?
  transactions     StockTransaction[]
  outletStocks     OutletStock[]
  products         Product[]
}



//////////////////////////////////////////////////////
// INVENTORY ENUMS
//////////////////////////////////////////////////////

enum InventoryStatus {
  ACTIVE
  INACTIVE
}

enum StockTransactionType {
  INITIALIZE
  ADD
  ADJUST
  TRANSFER
}

enum StockSource {
  CENTRAL
  ADJUSTMENT
}

enum StockDestination {
  CENTRAL
  OUTLET
}

//////////////////////////////////////////////////////
// CENTRAL INVENTORY (SOURCE OF TRUTH)
//////////////////////////////////////////////////////

model CentralInventory {
  id           String @id @default(uuid())

  stockItemId  String @unique
  stockItem    StockItem @relation(fields: [stockItemId], references: [id])

  unit         Unit

  availableQty Decimal @db.Decimal(12, 3) @default(0)
  totalQty     Decimal @db.Decimal(12, 3) @default(0)

  status       InventoryStatus @default(ACTIVE)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  transactions StockTransaction[]

  @@index([stockItemId])
  @@index([status])
}


//////////////////////////////////////////////////////
// STOCK TRANSACTIONS (AUDIT LOG)
//////////////////////////////////////////////////////

model StockTransaction {
  id              String @id @default(uuid())

  stockItemId     String
  stockItem       StockItem @relation(fields: [stockItemId], references: [id])

  inventoryId     String
  inventory       CentralInventory @relation(fields: [inventoryId], references: [id])

  type            StockTransactionType
  quantity        Decimal @db.Decimal(12, 3)

  source          StockSource
  destination     StockDestination

  outletId        String?
  performedBy     String?   // superAdminId
  remarks         String?

  createdAt       DateTime @default(now())

  @@index([stockItemId])
  @@index([inventoryId])
  @@index([type])
  @@index([createdAt])
}


//////////////////////////////////////////////////////
// OUTLET STOCK (PER OUTLET)
//////////////////////////////////////////////////////

model OutletStock {
  id          String @id @default(uuid())

  outletId    String
  outlet      Outlet @relation(fields: [outletId], references: [id])

  stockItemId String
  stockItem   StockItem @relation(fields: [stockItemId], references: [id])

  unit        Unit
  quantity    Decimal @db.Decimal(12, 3) @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([outletId, stockItemId])
  @@index([outletId])
  @@index([stockItemId])
}


//////////////////////////////////////////////////////
// PRODUCT ENUMS
//////////////////////////////////////////////////////

enum ProductStatus {
  ACTIVE
  INACTIVE
}

enum UnitType {
  ML
  LTR
  G
  KG
  PCS
}

enum ProductTag {
  FRESH
  ORGANIC
  NO_SUGAR
  COLD_PRESSED
  NATURAL
  FARM_FRESH
  PRESERVATIVE_FREE
  VEGAN
}


//////////////////////////////////////////////////////
// PRODUCT
//////////////////////////////////////////////////////

model Product {
  id                String        @id @default(uuid())

  categoryId        String
  category          Category      @relation(fields: [categoryId], references: [id])

  stockItemId       String
  stockItem         StockItem     @relation(fields: [stockItemId], references: [id])

  productName       String        @unique @db.VarChar(150)
  slug              String        @unique @db.VarChar(180)

  shortDescription  String?       @db.VarChar(300)
  longDescription   String?

  originalPrice     Decimal       @db.Decimal(12, 2)
  discountPrice     Decimal?      @db.Decimal(12, 2)

  mainImage         String
  galleryImages     ProductImage[]

  // 🏷 TAGS
  tags              ProductTag[]  @default([])
  sortOrder         Int           @default(0)

  // 📏 UNIT
  unitValue         Int
  unitType          UnitType

  ratingAverage     Decimal?      @db.Decimal(3, 2)
  ratingCount       Int           @default(0)

  // 🔥 NEW (very useful)
  isFeatured        Boolean       @default(false)

  isTrending        Boolean       @default(false)
  isAvailable       Boolean       @default(true)


  // 🔥 NEW CONTENT FIELDS (added)

  ingredients       String?       @db.Text
  benefits          String?       @db.Text

  extraInfo1        String?       @db.VarChar(255) // flexible label/value
  extraInfo2        String?       @db.VarChar(255)

  status            ProductStatus @default(ACTIVE)
  createdBy         String

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?

  //////////////////////////////////////////////////
  // INDEXES (performance upgrades)
  //////////////////////////////////////////////////

  @@index([deletedAt]) // soft delete filter
  @@index([slug, status, isAvailable]) // fast slug fetch
  @@index([categoryId, status, isAvailable, sortOrder]) // public listing
  @@index([isTrending])
  @@index([isFeatured])
  @@index([productName])
  @@index([stockItemId])

  carts CartItem[]
  outlets OutletProduct[]
  orderItems OrderItem[]
}

//////////////////////////////////////////////////////
// PRODUCT IMAGES
//////////////////////////////////////////////////////

model ProductImage {
  id        String   @id @default(uuid())

  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  imageUrl  String
  sortOrder Int      @default(0)

  createdAt DateTime @default(now())

  // 🔥 faster gallery loading
  @@index([productId, sortOrder])
}



//////////////////////////////////////////////////////
// cart +cartitems 
//////////////////////////////////////////////////////


enum CartStatus {
  ACTIVE
  LOCKED
  EXPIRED
}

model Cart {
  id String @id @default(cuid())

  customerId String?
  sessionId  String?

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)

  outletId String
  outlet   Outlet @relation(fields: [outletId], references: [id])

  status  CartStatus @default(ACTIVE)
  orderId String?

  currency String @default("INR")

  //////////////////////////////////////////////////
  // 🔥 ADD THESE (summary cache for frontend)
  //////////////////////////////////////////////////
  subtotal     Decimal @db.Decimal(12,2) @default(0)
  discount     Decimal @db.Decimal(12,2) @default(0)
  afterDiscountTotal Decimal @db.Decimal(12,2)  @default(0)
  deliveryFee  Decimal @db.Decimal(12,2) @default(0)
  grandTotal   Decimal @db.Decimal(12,2) @default(0)
  itemCount    Int     @default(0)
  //////////////////////////////////////////////////

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lockedAt  DateTime?
  expiresAt DateTime?

  items CartItem[]
  order Order?

  @@index([customerId])
  @@index([outletId])
  @@index([status])
  @@index([sessionId])

}

model CartItem {
  id String @id @default(cuid())

  cartId String
  cart   Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity Int @default(1)
  lineTotal Decimal @db.Decimal(12,2) // 🔥 add

  unitPrice     Decimal  @db.Decimal(12, 2)
  discountPrice Decimal? @db.Decimal(12, 2)

  productName  String
  productImage String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([productId])
}


//////////////////////////////////////////////////////
// saved address
//////////////////////////////////////////////////////

enum SavedAddressType {
  HOME
  WORK
  OTHER
}

model CustomerSavedAddress {
  id          String   @id @default(cuid())

  // 🔗 OWNERSHIP
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // 🏷️ ADDRESS META
  type        SavedAddressType
  label       String   @db.VarChar(50) // custom name (used mainly for OTHER)
  addressText String   @db.Text

  latitude    Float?
  longitude   Float?

  // 🗑️ SOFT DELETE
  isDeleted   Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([customerId])
  @@index([type])
  @@index([isDeleted])
}

//////////////////////////////////////////////////////
// ORDER
//////////////////////////////////////////////////////

enum OrderStatus {
  CREATED          // order created, before payment
  PAYMENT_PENDING  // payment initiated
  PAID             // payment success
  CONFIRMED        // outlet accepted
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  FAILED
}

model Order {
  id String @id @default(cuid())

  //////////////////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////////////////

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  outletId String
  outlet   Outlet @relation(fields: [outletId], references: [id])

  cartId String? @unique
  cart   Cart? @relation(fields: [cartId], references: [id])

  //////////////////////////////////////////////////
  // ADDRESS SNAPSHOT
  //////////////////////////////////////////////////

  addressLabel String
  addressText  String
  latitude     Float?
  longitude    Float?

  currency String @default("INR")

//////////////////////////////////////////////////
// 🔥 MONEY SNAPSHOT (CACHED LIKE CART)
//////////////////////////////////////////////////

subtotal           Decimal @db.Decimal(12,2)
discount           Decimal @db.Decimal(12,2)
afterDiscountTotal Decimal @db.Decimal(12,2)
deliveryFee        Decimal @db.Decimal(12,2)
grandTotal         Decimal @db.Decimal(12,2)
itemCount          Int

  status OrderStatus @default(CREATED)
  version Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  //////////////////////////////////////////////////

  items    OrderItem[]
  payments Payment[]
  events OrderEvent[]
  delivery Delivery?

  paidAt DateTime?
confirmedAt DateTime?
preparingAt DateTime?
outForDeliveryAt DateTime?
deliveredAt DateTime?
cancelledAt DateTime?
failedAt DateTime?

  //////////////////////////////////////////////////

  @@index([customerId])
  @@index([outletId])
  @@index([status])
  @@index([createdAt])
  @@index([customerId, outletId, status])
}


//////////////////////////////////////////////////////
// ORDER ITEMS
//////////////////////////////////////////////////////

model OrderItem {
  id String @id @default(cuid())

  orderId String
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  // snapshot
  productName  String
  productImage String

  quantity Int

  unitPrice     Decimal @db.Decimal(12,2)
  discountPrice Decimal? @db.Decimal(12,2)

  totalPrice Decimal @db.Decimal(12,2)

  createdAt DateTime @default(now())

  @@index([orderId])
}


//////////////////////////////////////////////////////
// PAYMENT
//////////////////////////////////////////////////////

enum PaymentMethod {
  ONLINE
  COD
}

enum PaymentStatus {
  INITIATED
  SUCCESS
  FAILED
  REFUNDED
}

model Payment {
  id String @id @default(cuid())

  orderId String
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  method PaymentMethod
  status PaymentStatus @default(INITIATED)
  attemptNo Int @default(1)

  provider        String?    // razorpay/stripe/phonepe
  providerRefId   String? @unique
  transactionId   String?

  amount      Decimal @db.Decimal(12,2)
  paidAmount  Decimal? @db.Decimal(12,2)   // 🔥 safer reconciliation

  failureReason String?                   // 🔥 added for debugging
  idempotencyKey String? @unique

  paidAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([status])
  @@index([providerRefId])
  @@index([createdAt])
  @@unique([orderId, attemptNo])
}

enum DeliveryTripStatus {
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
}

model Delivery {
  id String @id @default(cuid())

  orderId String @unique
  order   Order @relation(fields: [orderId], references: [id])

  partnerId String
  partner   DeliveryPartner @relation(fields: [partnerId], references: [id])

  status DeliveryTripStatus @default(ASSIGNED)

  assignedAt  DateTime @default(now())
  pickedUpAt  DateTime?
  deliveredAt DateTime?
  failedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  locations DeliveryLocation[]
  events DeliveryEvent[]

  @@index([partnerId])
  @@index([status])
  @@index([createdAt])
}


model DeliveryLocation {
  id String @id @default(cuid())

  deliveryId String
  delivery   Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  lat Float
  lng Float

  createdAt DateTime @default(now())

  @@index([deliveryId])
  @@index([deliveryId, createdAt])
}


enum OrderEventType {
  CREATED
  PAYMENT_PENDING
  PAID
  CONFIRMED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  FAILED
}
model OrderEvent {
  id String @id @default(cuid())

  orderId String
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  type OrderEventType

  // who triggered
  actorType ActorType?
  actorId   String?

  // extra info
  note      String?
  metadata  Json?

  // retry safety
  idempotencyKey String? @unique

  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
  @@index([type, createdAt])
  @@index([orderId, type])
}

enum DeliveryEventType {
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
  LOCATION_UPDATED
}

model DeliveryEvent {
  id String @id @default(cuid())

  deliveryId String
  delivery   Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  type DeliveryEventType
  metadata Json?

  createdAt DateTime @default(now())

  @@index([deliveryId, createdAt])
  @@index([type, createdAt])
}